{
  "name": "landsearch",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:web": "npm --workspace @landsearch/web run dev",
    "build:web": "npm --workspace @landsearch/web run build",
    "dev:worker": "npm --workspace @landsearch/worker run dev",
    "start": "npm --workspace @landsearch/worker run build && npm --workspace @landsearch/worker run start"
  }
}
